# Скопируйте этот файл в  .env  (рядом с run.cmd) и впишите свои значения.
# .env читается автоматически и ботом, и веб-версией. Файл .env в git не попадает.

# --- Telegram-бот ---
# 1) Напишите @BotFather в Telegram, команда /newbot, получите токен.
# 2) Узнайте свой Telegram-id у @userinfobot и впишите его ниже.
SPENDTRACK_TOKEN=ВСТАВЬТЕ_ТОКЕН_ОТ_BOTFATHER
SPENDTRACK_ALLOWED=ВАШ_TELEGRAM_ID

# Чтобы веб показывал записи, добавленные ботом, user_id должен совпадать.
# По умолчанию берётся первый из SPENDTRACK_ALLOWED — обычно менять не нужно.
# SPENDTRACK_WEB_USER=ВАШ_TELEGRAM_ID

# --- Веб-версия ---
# PIN на вход в веб (необязательно). Пусто = без пароля (ок для localhost).
SPENDTRACK_PIN=

# Валюта по умолчанию
SPENDTRACK_CURRENCY=PLN
