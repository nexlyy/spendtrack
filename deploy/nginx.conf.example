# Пример обратного прокси для веб-версии SpendTrack.
# Веб-сервис слушает 127.0.0.1:8770; nginx завершает TLS и проксирует на него.
# TLS-сертификат удобно получить через certbot (Let's Encrypt).
#
# Важно: на сервере уже занят порт 8765 другим ботом — здесь конфликта нет,
# веб использует 8770 локально, а наружу торчит только 443.

server {
    listen 80;
    server_name spend.example.com;
    # редирект на HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name spend.example.com;

    ssl_certificate     /etc/letsencrypt/live/spend.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/spend.example.com/privkey.pem;

    # Лёгкое сжатие статики
    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    location / {
        proxy_pass http://127.0.0.1:8770;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
