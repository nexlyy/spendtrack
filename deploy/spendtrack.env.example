# Образец переменных окружения SpendTrack (без реальных секретов).
# На сервере положить в /etc/spendtrack/spendtrack.env с правами 600.

# --- Telegram-бот ---
# Токен от @BotFather (отдельный от других ботов на сервере).
SPENDTRACK_TOKEN=123456:replace-me
# Telegram-id разрешённых пользователей через запятую. Бот игнорирует всех
# остальных. Свой id можно узнать у @userinfobot.
SPENDTRACK_ALLOWED=111111111

# --- Общее (бот и веб используют одну базу — источник истины) ---
SPENDTRACK_DB=/var/lib/spendtrack/spend.db
SPENDTRACK_VAULT=/var/lib/spendtrack/vault
SPENDTRACK_CURRENCY=PLN

# --- Веб-версия ---
SPENDTRACK_HOST=127.0.0.1
SPENDTRACK_PORT=8770
# PIN для входа в веб. Пусто = без авторизации (только если веб не торчит наружу).
SPENDTRACK_PIN=2580
# Под каким user_id веб создаёт записи и фильтрует выборки.
# По умолчанию берётся первый из SPENDTRACK_ALLOWED.
SPENDTRACK_WEB_USER=111111111
